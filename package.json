{
  "name": "@stevysmith/agentk",
  "version": "0.4.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "A command palette for the agentic web — forked from cmdk with WebMCP primitives",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.mjs",
      "require": "./dist/providers.js"
    },
    "./providers/anthropic": {
      "types": "./dist/providers/anthropic.d.ts",
      "import": "./dist/providers/anthropic.mjs",
      "require": "./dist/providers/anthropic.js"
    },
    "./providers/openai": {
      "types": "./dist/providers/openai.d.ts",
      "import": "./dist/providers/openai.mjs",
      "require": "./dist/providers/openai.js"
    },
    "./providers/google": {
      "types": "./dist/providers/google.d.ts",
      "import": "./dist/providers/google.mjs",
      "require": "./dist/providers/google.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@radix-ui/react-compose-refs": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-id": "^1.1.0",
    "@radix-ui/react-primitive": "^2.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "jsdom": "^25.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/stevysmith/agentk"
  },
  "homepage": "https://agentk-ya5h.onrender.com",
  "author": "Steve Smith",
  "keywords": [
    "command-palette",
    "cmdk",
    "webmcp",
    "agent",
    "ai",
    "react"
  ]
}
